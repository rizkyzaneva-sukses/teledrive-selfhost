PORT=3000

# Create via @BotFather, then add the bot as admin/member to your private storage channel.
BOT_TOKEN=123456789:replace_me

# Private channel/group ID, usually starts with -100.
# Send one test message to the channel, then use getUpdates or @RawDataBot to inspect the chat ID.
STORAGE_CHAT_ID=-1001234567890

# Optional. If filled, web/API requests must include this token.
ADMIN_TOKEN=change-this-token

# Max upload size accepted by this app. Telegram Bot API limit depends on your bot/API setup.
MAX_UPLOAD_MB=50
